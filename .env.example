# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Kane's Portfolio

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio

# NestJS API
API_PORT=3001
JWT_SECRET=your-jwt-secret-here
# PRODUCTION: Set to your public URL (e.g., https://portfolio.haunguyendev.xyz)
# Required for CORS when making direct browser-to-API calls
CORS_ORIGIN=http://localhost:3000

# Better Auth
BETTER_AUTH_SECRET=your-better-auth-secret-here
# PRODUCTION: MUST be your public HTTPS URL for OAuth callbacks and secure cookies
# Example: BETTER_AUTH_URL=https://portfolio.haunguyendev.xyz
# If wrong, GitHub OAuth will redirect to localhost and cookies won't work
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth
# Create OAuth App at https://github.com/settings/developers
# Callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
# PRODUCTION callback: https://portfolio.haunguyendev.xyz/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=portfolio-media
MINIO_USE_SSL=false
